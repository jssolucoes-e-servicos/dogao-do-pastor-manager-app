{
  "expo": {
    "name": "Dogão do Pastor - Equipe",
    "slug": "dogao-do-pastor-manager-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/c777440e-79dc-4bb5-93e4-2b0989fc7d82",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.com.jssolucoeseservicos.dogaodopastor.manager"
    },
    "android": {
      "package": "br.com.jssolucoeseservicos.dogaodopastor.manager",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#ea580c",
        "foregroundImage": "./src/assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/favicon.png",
      "bundler": "metro",
      "name": "Dogão do Pastor - Equipe",
      "shortName": "Dogão Equipe",
      "description": "App da equipe de vendedores do Dogão do Pastor",
      "themeColor": "#ea580c",
      "backgroundColor": "#ea580c",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ea580c",
          "dark": {
            "backgroundColor": "#c2410c"
          }
        }
      ],
      "expo-secure-store",
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#ea580c",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Permitir que $(PRODUCT_NAME) acesse seu calendário."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que $(PRODUCT_NAME) acesse sua câmera",
          "microphonePermission": "Permitir que $(PRODUCT_NAME) acesse seu microfone",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c777440e-79dc-4bb5-93e4-2b0989fc7d82"
      },
      "router": {}
    },
    "owner": "grupots"
  }
}
